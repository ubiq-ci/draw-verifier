{
  "name": "@ubiq-ci/draw-verifier",
  "version": "0.2.0",
  "description": "Independent verifier for signed lottery draw ledgers.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "draw-verifier": "dist/src/cli.js"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "build:web": "tsc && esbuild dist/src/index.js --bundle --format=esm --outfile=web/draw-verifier.js",
    "test": "tsc && node --test dist/test/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "typescript": "5.6.3"
  }
}
